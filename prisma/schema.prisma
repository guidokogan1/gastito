generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

model Household {
  id             String          @id @default(cuid())
  name           String
  baseCurrency   String          @default("ARS")
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  memberships    Membership[]
  categories     Category[]
  paymentMethods PaymentMethod[]
  accounts       Account[]
  transactions   Transaction[]
  debts          Debt[]
  recurringBills RecurringBill[]
  debtPayments   DebtPayment[]
  recurringBillPayments RecurringBillPayment[]
}

model AuditLog {
  id          String      @id @default(cuid())
  userId      String?
  householdId String?
  requestId   String?
  action      String
  targetType  String?
  targetId    String?
  result      AuditResult @default(success)
  before      Json?
  after       Json?
  errorCode   String?
  ipHash      String?
  metadata    Json?
  createdAt   DateTime    @default(now())

  @@index([householdId, createdAt])
  @@index([userId, createdAt])
  @@index([requestId])
  @@index([action, createdAt])
}

model RateLimitBucket {
  id        String   @id @default(cuid())
  key       String   @unique
  count     Int      @default(0)
  resetAt   DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([resetAt])
}

model Membership {
  id          String         @id @default(cuid())
  authUserId  String
  householdId String
  role        MembershipRole @default(owner)
  createdAt   DateTime       @default(now())
  household   Household      @relation(fields: [householdId], references: [id], onDelete: Cascade)

  @@index([authUserId])
  @@unique([authUserId, householdId])
}

model Category {
  id           String        @id @default(cuid())
  householdId  String
  name         String
  isActive     Boolean       @default(true)
  deletedAt    DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  household    Household     @relation(fields: [householdId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@unique([householdId, name])
  @@index([householdId, isActive, name])
}

model PaymentMethod {
  id             String          @id @default(cuid())
  householdId    String
  name           String
  isActive       Boolean         @default(true)
  deletedAt      DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  household      Household       @relation(fields: [householdId], references: [id], onDelete: Cascade)
  transactions   Transaction[]
  recurringBills RecurringBill[]
  recurringBillPayments RecurringBillPayment[]

  @@unique([householdId, name])
  @@index([householdId, isActive, name])
}

model Account {
  id           String        @id @default(cuid())
  householdId  String
  name         String
  type         AccountType   @default(cash)
  isActive     Boolean       @default(true)
  deletedAt    DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  household    Household     @relation(fields: [householdId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@unique([householdId, name])
  @@index([householdId, isActive, name])
}

model Transaction {
  id              String          @id @default(cuid())
  householdId     String
  accountId       String?
  categoryId      String?
  paymentMethodId String?
  date            DateTime        @db.Date
  amount          Decimal         @db.Decimal(12, 2)
  type            TransactionType
  detail          String?
  deletedAt       DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  account         Account?        @relation(fields: [accountId], references: [id], onDelete: SetNull)
  category        Category?       @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  household       Household       @relation(fields: [householdId], references: [id], onDelete: Cascade)
  paymentMethod   PaymentMethod?  @relation(fields: [paymentMethodId], references: [id], onDelete: SetNull)

  @@index([householdId, date])
  @@index([householdId, type, date])
  @@index([householdId, categoryId, date])
}

model Debt {
  id               String        @id @default(cuid())
  householdId      String
  entityName       String
  direction        DebtDirection @default(we_owe)
  originalAmount   Decimal       @db.Decimal(12, 2)
  remainingBalance Decimal       @db.Decimal(12, 2)
  notes            String?
  isActive         Boolean       @default(true)
  deletedAt        DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  household        Household     @relation(fields: [householdId], references: [id], onDelete: Cascade)
  payments         DebtPayment[]

  @@index([householdId, isActive])
  @@index([householdId, isActive, createdAt])
}

model DebtPayment {
  id          String   @id @default(cuid())
  householdId String
  debtId      String
  date        DateTime @db.Date
  amount      Decimal  @db.Decimal(12, 2)
  notes       String?
  deletedAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  household   Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  debt        Debt      @relation(fields: [debtId], references: [id], onDelete: Cascade)

  @@index([householdId, debtId, date])
}

model RecurringBill {
  id              String         @id @default(cuid())
  householdId     String
  paymentMethodId String?
  name            String
  amount          Decimal        @default(0) @db.Decimal(12, 2)
  dueDay          Int
  notes           String?
  isActive        Boolean        @default(true)
  deletedAt       DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  household       Household      @relation(fields: [householdId], references: [id], onDelete: Cascade)
  paymentMethod   PaymentMethod? @relation(fields: [paymentMethodId], references: [id], onDelete: SetNull)
  payments        RecurringBillPayment[]

  @@index([householdId, isActive])
  @@index([householdId, isActive, dueDay])
}

model RecurringBillPayment {
  id              String         @id @default(cuid())
  householdId     String
  recurringBillId String
  paymentMethodId String?
  issuedAt        DateTime?      @db.Date
  dueDate         DateTime       @db.Date
  paidAt          DateTime?      @db.Date
  amount          Decimal        @db.Decimal(12, 2)
  notes           String?
  deletedAt       DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  household       Household      @relation(fields: [householdId], references: [id], onDelete: Cascade)
  recurringBill   RecurringBill  @relation(fields: [recurringBillId], references: [id], onDelete: Cascade)
  paymentMethod   PaymentMethod? @relation(fields: [paymentMethodId], references: [id], onDelete: SetNull)

  @@index([householdId, recurringBillId, dueDate])
  @@index([householdId, paidAt])
}

enum MembershipRole {
  owner
}

enum AccountType {
  cash
  bank
  wallet
}

enum TransactionType {
  expense
  income
}

enum DebtDirection {
  we_owe
  they_owe_us
}

enum AuditResult {
  success
  failure
}

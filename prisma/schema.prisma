generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("PUBLIC_APP_DATABASE_URL")
  directUrl = env("PUBLIC_APP_DIRECT_URL")
}

model Household {
  id             String          @id @default(cuid())
  name           String
  baseCurrency   String          @default("ARS")
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  memberships    Membership[]
  categories     Category[]
  paymentMethods PaymentMethod[]
  accounts       Account[]
  transactions   Transaction[]
  debts          Debt[]
  recurringBills RecurringBill[]
}

model Membership {
  id          String    @id @default(cuid())
  authUserId  String
  householdId String
  role        String    @default("owner")
  createdAt   DateTime  @default(now())
  household   Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  @@index([authUserId])
  @@unique([authUserId, householdId])
}

model Category {
  id          String        @id @default(cuid())
  householdId String
  name        String
  isActive    Boolean       @default(true)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  household   Household     @relation(fields: [householdId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@unique([householdId, name])
}

model PaymentMethod {
  id             String          @id @default(cuid())
  householdId    String
  name           String
  isActive       Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  household      Household       @relation(fields: [householdId], references: [id], onDelete: Cascade)
  transactions   Transaction[]
  recurringBills RecurringBill[]

  @@unique([householdId, name])
}

model Account {
  id           String        @id @default(cuid())
  householdId  String
  name         String
  type         String        @default("cash")
  isActive     Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  household    Household     @relation(fields: [householdId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@unique([householdId, name])
}

model Transaction {
  id              String         @id @default(cuid())
  householdId     String
  accountId       String?
  categoryId      String?
  paymentMethodId String?
  date            DateTime
  amount          Float
  type            String
  detail          String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  account         Account?       @relation(fields: [accountId], references: [id], onDelete: SetNull)
  category        Category?      @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  household       Household      @relation(fields: [householdId], references: [id], onDelete: Cascade)
  paymentMethod   PaymentMethod? @relation(fields: [paymentMethodId], references: [id], onDelete: SetNull)

  @@index([householdId, date])
}

model Debt {
  id               String    @id @default(cuid())
  householdId      String
  entityName       String
  direction        String    @default("we_owe")
  originalAmount   Float
  remainingBalance Float
  notes            String?
  isActive         Boolean   @default(true)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  household        Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  @@index([householdId, isActive])
}

model RecurringBill {
  id              String         @id @default(cuid())
  householdId     String
  paymentMethodId String?
  name            String
  amount          Float
  dueDay          Int
  notes           String?
  isActive        Boolean        @default(true)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  household       Household      @relation(fields: [householdId], references: [id], onDelete: Cascade)
  paymentMethod   PaymentMethod? @relation(fields: [paymentMethodId], references: [id], onDelete: SetNull)

  @@index([householdId, isActive])
}

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

model Household {
  id             String          @id @default(cuid())
  name           String
  baseCurrency   String          @default("ARS")
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  memberships    Membership[]
  banks           Bank[]
  categories     Category[]
  paymentMethods PaymentMethod[]
  accounts       Account[]
  transactions   Transaction[]
  debts          Debt[]
  recurringBills RecurringBill[]
  debtPayments   DebtPayment[]
  recurringBillPayments RecurringBillPayment[]
}

model AuditLog {
  id          String      @id @default(cuid())
  userId      String?
  householdId String?
  requestId   String?
  action      String
  targetType  String?
  targetId    String?
  result      AuditResult @default(success)
  before      Json?
  after       Json?
  errorCode   String?
  ipHash      String?
  metadata    Json?
  createdAt   DateTime    @default(now())

  @@index([householdId, createdAt])
  @@index([userId, createdAt])
  @@index([requestId])
  @@index([action, createdAt])
}

model RateLimitBucket {
  id        String   @id @default(cuid())
  key       String   @unique
  count     Int      @default(0)
  resetAt   DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([resetAt])
}

model Membership {
  id          String         @id @default(cuid())
  authUserId  String
  householdId String
  role        MembershipRole @default(owner)
  createdAt   DateTime       @default(now())
  household   Household      @relation(fields: [householdId], references: [id], onDelete: Cascade)

  @@index([authUserId])
  @@unique([authUserId, householdId])
}

model Category {
  id           String        @id @default(cuid())
  householdId  String
  name         String
  icon         String        @default("tag")
  color        String        @default("#F7F7F8")
  budget       Decimal       @default(0) @db.Decimal(12, 2)
  sortOrder    Int           @default(0)
  kind         CategoryKind  @default(expense)
  isActive     Boolean       @default(true)
  deletedAt    DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  household    Household     @relation(fields: [householdId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@unique([householdId, name])
  recurringBills RecurringBill[]

  @@index([householdId, isActive, kind, sortOrder])
}

model Bank {
  id             String          @id @default(cuid())
  householdId    String
  name           String
  color          String          @default("#0E3B2E")
  deletedAt      DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  household      Household       @relation(fields: [householdId], references: [id], onDelete: Cascade)
  paymentMethods PaymentMethod[]

  @@unique([householdId, name])
  @@index([householdId, name])
}

model PaymentMethod {
  id             String          @id @default(cuid())
  householdId    String
  bankId         String?
  name           String
  type           PaymentMethodType @default(cash)
  last4          String?
  isActive       Boolean         @default(true)
  deletedAt      DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  household      Household       @relation(fields: [householdId], references: [id], onDelete: Cascade)
  bank           Bank?           @relation(fields: [bankId], references: [id], onDelete: SetNull)
  transactions   Transaction[]
  recurringBills RecurringBill[]
  recurringBillPayments RecurringBillPayment[]

  @@unique([householdId, name])
  @@index([householdId, isActive, name])
  @@index([householdId, bankId])
}

model Account {
  id           String        @id @default(cuid())
  householdId  String
  name         String
  type         AccountType   @default(cash)
  isActive     Boolean       @default(true)
  deletedAt    DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  household    Household     @relation(fields: [householdId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@unique([householdId, name])
  @@index([householdId, isActive, name])
}

model Transaction {
  id              String          @id @default(cuid())
  householdId     String
  accountId       String?
  categoryId      String?
  paymentMethodId String?
  date            DateTime        @db.Date
  amount          Decimal         @db.Decimal(12, 2)
  type            TransactionType
  sourceType      TransactionSourceType?
  sourceId        String?
  detail          String?
  deletedAt       DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  account         Account?        @relation(fields: [accountId], references: [id], onDelete: SetNull)
  category        Category?       @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  household       Household       @relation(fields: [householdId], references: [id], onDelete: Cascade)
  paymentMethod   PaymentMethod?  @relation(fields: [paymentMethodId], references: [id], onDelete: SetNull)
  debtPayments    DebtPayment[]
  recurringBillPayments RecurringBillPayment[]

  @@index([householdId, date])
  @@index([householdId, type, date])
  @@index([householdId, categoryId, date])
  @@index([householdId, sourceType, sourceId])
}

model Debt {
  id               String        @id @default(cuid())
  householdId      String
  entityName       String
  direction        DebtDirection @default(we_owe)
  originalAmount   Decimal       @db.Decimal(12, 2)
  remainingBalance Decimal       @db.Decimal(12, 2)
  notes            String?
  isActive         Boolean       @default(true)
  deletedAt        DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  household        Household     @relation(fields: [householdId], references: [id], onDelete: Cascade)
  payments         DebtPayment[]

  @@index([householdId, isActive])
  @@index([householdId, isActive, createdAt])
}

model DebtPayment {
  id          String   @id @default(cuid())
  householdId String
  debtId      String
  date        DateTime @db.Date
  amount      Decimal  @db.Decimal(12, 2)
  transactionId String?
  notes       String?
  deletedAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  household   Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  debt        Debt      @relation(fields: [debtId], references: [id], onDelete: Cascade)
  transaction Transaction? @relation(fields: [transactionId], references: [id], onDelete: SetNull)

  @@index([householdId, debtId, date])
  @@index([householdId, transactionId])
}

model RecurringBill {
  id              String         @id @default(cuid())
  householdId     String
  paymentMethodId String?
  defaultCategoryId String?
  name            String
  icon            String         @default("repeat")
  amount          Decimal        @default(0) @db.Decimal(12, 2)
  dueDay          Int
  notes           String?
  isActive        Boolean        @default(true)
  deletedAt       DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  household       Household      @relation(fields: [householdId], references: [id], onDelete: Cascade)
  paymentMethod   PaymentMethod? @relation(fields: [paymentMethodId], references: [id], onDelete: SetNull)
  defaultCategory Category?      @relation(fields: [defaultCategoryId], references: [id], onDelete: SetNull)
  payments        RecurringBillPayment[]

  @@index([householdId, isActive])
  @@index([householdId, isActive, dueDay])
  @@index([householdId, defaultCategoryId])
}

model RecurringBillPayment {
  id              String         @id @default(cuid())
  householdId     String
  recurringBillId String
  paymentMethodId String?
  issuedAt        DateTime?      @db.Date
  dueDate         DateTime       @db.Date
  paidAt          DateTime?      @db.Date
  amount          Decimal        @db.Decimal(12, 2)
  transactionId   String?
  notes           String?
  deletedAt       DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  household       Household      @relation(fields: [householdId], references: [id], onDelete: Cascade)
  recurringBill   RecurringBill  @relation(fields: [recurringBillId], references: [id], onDelete: Cascade)
  paymentMethod   PaymentMethod? @relation(fields: [paymentMethodId], references: [id], onDelete: SetNull)
  transaction     Transaction?   @relation(fields: [transactionId], references: [id], onDelete: SetNull)

  @@index([householdId, recurringBillId, dueDate])
  @@index([householdId, paidAt])
  @@index([householdId, transactionId])
}

enum MembershipRole {
  owner
}

enum AccountType {
  cash
  bank
  wallet
}

enum CategoryKind {
  expense
  income
}

enum PaymentMethodType {
  credit
  debit
  wallet
  cash
  transfer
  auto
}

enum TransactionType {
  expense
  income
}

enum TransactionSourceType {
  recurring_bill_payment
  debt_payment
}

enum DebtDirection {
  we_owe
  they_owe_us
}

enum AuditResult {
  success
  failure
}
